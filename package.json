{
  "name": "real-time-analyzer",
  "version": "1.0.0",
  "description": "Real-Time Audio Analyzer with spectrum visualization",
  "author": {
    "name": "fsavoure",
    "email": "contact@example.com"
  },
  "homepage": "https://github.com/fsavoure/rta",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "predev": "pnpm wasm:build",
    "dev": "vite",
    "prebuild": "pnpm wasm:build:release",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:preview": "node scripts/electron-preview.mjs",
    "wasm:build": "wasm-pack build wasm/metadata --target web --no-opt --out-dir ../../src/wasm/metadata --out-name rta_metadata_wasm",
    "wasm:build:release": "wasm-pack build wasm/metadata --release --target web --no-opt --out-dir ../../src/wasm/metadata --out-name rta_metadata_wasm"
  },
  "dependencies": {
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.3",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.2",
    "wasm-pack": "^0.13.0"
  }
}
