{
  appId: "com.rta.app",
  productName: "RTA",
  directories: {
    buildResources: "build",
    output: "release"
  },
  files: [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  mac: {
    target: [
      "dmg",
      "zip"
    ],
    category: "public.app-category.music"
  },
  win: {
    target: [
      "nsis",
      "portable"
    ]
  },
  linux: {
    target: [
      "AppImage"
    ],
    category: "Audio"
  },
  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true
  }
}
